---
import BaseTemplate from "layouts/BaseTemplate/BaseTemplate.astro";

const { title } = Astro.props;

// ID de Google Analytics - configurar en .env o reemplazar con tu ID real
import GoogleAnalytics from "components/GoogleAnalytics/GoogleAnalytics.astro";
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";
---

<BaseTemplate title={title}>
	{import.meta.env.PROD && GA_MEASUREMENT_ID && (
		<GoogleAnalytics slot="gtag" measurementId={GA_MEASUREMENT_ID} />
	)}
	<div class="w-screen h-screen bg-gray-900" slot="body">
		<slot name="background" />
		<main>
			<slot name="main" />
		</main>
	</div>
</BaseTemplate>
